@model EmployeesCh12.Models.Department

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Department</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mt-2">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>

    <div class="col-md-8">
        <h5>Locations</h5>
        <p class="text-muted">
            Locations for this department are managed via the Department Locations page.
        </p>
        @if (Model.DepartmentLocations != null && Model.DepartmentLocations.Any())
        {
            <ul>
                @foreach (var dl in Model.DepartmentLocations)
                {
                    if (dl.Location != null)
                    {
                        <li>@dl.Location.Address</li>
                    }
                }
            </ul>
        }
        else
        {
            <p>None</p>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
